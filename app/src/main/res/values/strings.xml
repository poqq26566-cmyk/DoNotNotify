    <string name="setup_welcome_title">Keep DoNotNotify alive</string>
    <string name="setup_welcome_body">Some Android phones aggressively shut down background apps to save battery — which would silently stop notification blocking. The next steps protect this app from being killed.</string>
    <string name="setup_welcome_cta">Get started</string>

    <string name="setup_listener_title">Grant notification access</string>
    <string name="setup_listener_body">DoNotNotify needs access to your notifications so it can filter and block them according to your rules.</string>
    <string name="setup_listener_cta">Open settings</string>
    <string name="setup_listener_granted">Granted</string>

    <string name="setup_battery_title">Disable battery optimization</string>
    <string name="setup_battery_body">Android puts apps to sleep to save battery (Doze). For DoNotNotify to keep filtering in the background, please allow it to run unrestricted.</string>
    <string name="setup_battery_cta">Allow unrestricted battery</string>
    <string name="setup_battery_granted">Allowed</string>

    <string name="setup_oem_title">Allow autostart on your phone</string>
    <string name="setup_oem_body_generic">Your phone\'s manufacturer adds an extra layer of background app restrictions. Tap below to open the relevant settings screen and enable autostart / background activity for DoNotNotify.</string>
    <string name="setup_oem_body_xiaomi">Xiaomi / MIUI aggressively kills background apps. Tap below to open Autostart settings, then enable DoNotNotify. Also check Battery &amp; performance → app battery saver → No restrictions.</string>
    <string name="setup_oem_body_huawei">Huawei / Honor restricts background apps via Phone Manager. Tap below to open Startup management, then turn on Auto-launch for DoNotNotify.</string>
    <string name="setup_oem_body_oppo">OPPO / ColorOS restricts background apps. Tap below to open Startup manager, then allow DoNotNotify to start automatically.</string>
    <string name="setup_oem_body_oneplus">OnePlus restricts background activity by default. Tap below to allow DoNotNotify to launch in the background.</string>
    <string name="setup_oem_body_vivo">Vivo restricts background apps. Tap below to open Background startup management, then allow DoNotNotify.</string>
    <string name="setup_oem_body_samsung">Samsung\'s Device Care can put DoNotNotify to sleep. Tap below to open Battery settings, then mark DoNotNotify as Unrestricted (Battery → Background usage limits).</string>
    <string name="setup_oem_body_asus">ASUS Mobile Manager restricts background apps. Tap below to open Auto-start manager and enable DoNotNotify.</string>
    <string name="setup_oem_body_letv">Letv restricts background apps. Tap below to open Autoboot management.</string>
    <string name="setup_oem_body_meizu">Meizu restricts background apps. Tap below to open Security settings.</string>
    <string name="setup_oem_body_nokia">Nokia uses an Evenwell power-saving layer that can kill DoNotNotify. Tap below to add it to the protected list.</string>
    <string name="setup_oem_cta">Open settings</string>
    <string name="setup_oem_done">I\'ve done this</string>
    <string name="setup_oem_failed">Couldn\'t open the settings screen. Please find the autostart or background-activity settings on your phone manually and allow DoNotNotify.</string>

    <string name="setup_post_notif_title">Allow DoNotNotify to post notifications</string>
    <string name="setup_post_notif_body">Stack rules re-post grouped notifications under DoNotNotify. Android 13+ requires you to allow this app to post notifications, or stacking will be inactive.</string>
    <string name="setup_post_notif_cta">Allow notifications</string>
    <string name="setup_post_notif_granted">Allowed</string>

